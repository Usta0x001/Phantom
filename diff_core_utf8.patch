-    </returns>
-    
-    <example>
-      <input>
-        cve_id = "CVE-2021-41773"
-      </input>
-      <output>
-        {
-          "cve_id": "CVE-2021-41773",
-          "tested": true,
-          "confirmed": true,
-          "status": "EXPLOITABLE",
-          "hypotheses": ["H-0042"]
-        }
-      </output>
-    </example>
-  </tool>
-</tools>
