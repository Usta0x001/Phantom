diff --git a/phantom/tools/fuzzer/fuzzer_actions_schema.xml b/phantom/tools/fuzzer/fuzzer_actions_schema.xml
index 4eb04ea..156b857 100644
--- a/phantom/tools/fuzzer/fuzzer_actions_schema.xml
+++ b/phantom/tools/fuzzer/fuzzer_actions_schema.xml
@@ -1,168 +1,2 @@
 <tools>
-  <tool name="execute_fuzz_batch">
-    <description>Execute a batch of AI-generated payloads in parallel against a target endpoint. Use this when you want to test multiple payloads efficiently. IMPORTANT: You MUST generate the payloads yourself based on the vulnerability context - do NOT use static payload lists. This tool is a pure executor that runs your payloads in parallel and returns response data.</description>
-    <parameters>
-      <parameter name="base_url" type="string" required="true">
-        <description>Target URL to fuzz. Use {FUZZ} marker for path injection:
-        - "https://target.com/api/users" (for param/header/body injection)
-        - "https://target.com/file/{FUZZ}" (for path injection)</description>
-      </parameter>
-      <parameter name="method" type="string" required="true">
-        <description>HTTP method to use:
-        - "GET": Most common for param/path testing
-        - "POST": For body/param testing
-        - "PUT", "DELETE", "PATCH": For specific API testing
-        - "OPTIONS", "HEAD": For HTTP method fuzzing</description>
-      </parameter>
-      <parameter name="payloads" type="List[str]" required="true">
-        <description>List of payloads YOU generated for this specific test. Based on the vulnerability context, generate targeted payloads. Examples:
-        
-        SQL Injection (MySQL):
-        ["' OR '1'='1'--", "1' UNION SELECT NULL,NULL--", "admin'--", "' OR 1=1#"]
-        
-        XSS:
-        ["&lt;script&gt;alert(1)&lt;/script&gt;", "&lt;img src=x onerror=alert(1)&gt;", "javascript:alert(1)"]
-        
-        Path Traversal:
-        ["../../../etc/passwd", "..\\..\\..\\windows\\system32\\config\\sam", "....//....//....//etc/passwd"]
-        
-        Command Injection:
-        ["; whoami", "| id", "` cat /etc/passwd `", "&amp;&amp; ls -la"]
-        
-        CRITICAL: Generate payloads contextually, don't use static lists!</description>
-      </parameter>
-      <parameter name="injection_point" type="string" required="true">
-        <description>Where to inject payloads:
-        - "param": URL parameter (requires param_name)
-        - "header": HTTP header (requires param_name for header name)
-        - "body": Request body (raw payload in POST data)
-        - "path": URL path (replace {FUZZ} marker in base_url)</description>
-      </parameter>
-      <parameter name="param_name" type="string" required="false">
-        <description>Parameter or header name to fuzz. Required for injection_point="param" or "header". Examples:
-        - "id" (for /api/users?id=PAYLOAD)
-        - "username" (for POST /login with username parameter)
-        - "X-Forwarded-For" (for header injection)</description>
-      </parameter>
-      <parameter name="headers" type="Dict[str, str]" required="false">
-        <description>Additional HTTP headers to include. Useful for:
-        - Authentication: {"Authorization": "Bearer TOKEN"}
-        - Content type: {"Content-Type": "application/json"}
-        - Custom headers: {"X-Custom-Header": "value"}</description>
-      </parameter>
-      <parameter name="timeout_seconds" type="float" required="false">
-        <description>Request timeout in seconds (default: 10.0). Increase for timing-based detection:
-        - 5.0: Fast fuzzing
-        - 10.0: Normal (default)
-        - 30.0: Blind SQL injection time-based detection</description>
-      </parameter>
-    </parameters>
-    <returns type="Dict[str, Any]">
-      <description>Batch execution results containing:
-        - 'batch_id': Unique ID for this batch (use with get_fuzz_results)
-        - 'total_requests': Number of payloads executed
-        - 'successful_requests': Requests that got responses
-        - 'failed_requests': Requests that errored
-        - 'status_code_distribution': {200: 5, 500: 2, ...} counts by status
-        - 'response_length_distribution': {1234: 3, 5678: 1, ...} counts by size
-        - 'timing_stats': {avg_ms, min_ms, max_ms} response times
-        - 'interesting_count': Number of responses with interesting markers
-        - 'interesting_results': List of results with anomalies/markers
-        - 'all_results': Full list of all results with details
-        
-      Each result includes:
-        - 'payload': The payload that was sent
-        - 'status_code': HTTP status code (or null if error)
-        - 'response_time_ms': Response time in milliseconds
-        - 'response_length': Response body size in bytes
-        - 'interesting_markers': List of detected anomalies like:
-          - "error_500": Server error
-          - "sql_error": SQL syntax error in response
-          - "lfi_success": File inclusion indicators
-          - "xss_reflection": Script reflection detected
-          - "error_in_response": Generic error/exception text
-          - "admin_debug_info": Admin/debug information leaked
-      </description>
-    </returns>
-    <examples>
-  # SQL injection fuzzing on GET parameter
-  <function=execute_fuzz_batch>
-  <parameter=base_url>https://target.com/api/users</parameter>
-  <parameter=method>GET</parameter>
-  <parameter=payloads>["' OR '1'='1'--", "1' UNION SELECT NULL--", "admin'--"]</parameter>
-  <parameter=injection_point>param</parameter>
-  <parameter=param_name>id</parameter>
-  </function>
-
-  # Path traversal fuzzing
-  <function=execute_fuzz_batch>
-  <parameter=base_url>https://target.com/file/{FUZZ}</parameter>
-  <parameter=method>GET</parameter>
-  <parameter=payloads>["../../../etc/passwd", "..\\..\\..\\windows\\win.ini", "....//....//etc/passwd"]</parameter>
-  <parameter=injection_point>path</parameter>
-  </function>
-
-  # XSS fuzzing in POST body
-  <function=execute_fuzz_batch>
-  <parameter=base_url>https://target.com/comment</parameter>
-  <parameter=method>POST</parameter>
-  <parameter=payloads>["&lt;script&gt;alert(1)&lt;/script&gt;", "&lt;img src=x onerror=alert(1)&gt;"]</parameter>
-  <parameter=injection_point>param</parameter>
-  <parameter=param_name>comment</parameter>
-  </function>
-
-  # Header injection for SSRF
-  <function=execute_fuzz_batch>
-  <parameter=base_url>https://target.com/api/proxy</parameter>
-  <parameter=method>GET</parameter>
-  <parameter=payloads>["http://internal-service:8080", "http://169.254.169.254/latest/meta-data/"]</parameter>
-  <parameter=injection_point>header</parameter>
-  <parameter=param_name>X-Forwarded-Host</parameter>
-  </function>
-    </examples>
-  </tool>
-
-  <tool name="get_fuzz_results">
-    <description>Get results from previous fuzz batches for detailed analysis.</description>
-    <parameters>
-      <parameter name="batch_id" type="string" required="false">
-        <description>Specific batch ID to retrieve (from execute_fuzz_batch response). If None, returns all batches summary.</description>
-      </parameter>
-    </parameters>
-    <returns type="Dict[str, Any]">
-      <description>Fuzz results with status codes, response times, lengths, and interesting markers.</description>
-    </returns>
-    <examples>
-  # Get specific batch results
-  <function=get_fuzz_results>
-  <parameter=batch_id>FUZZ-A1B2C3D4</parameter>
-  </function>
-
-  # Get all batches summary
-  <function=get_fuzz_results>
-  </function>
-    </examples>
-  </tool>
-
-  <tool name="clear_fuzz_results">
-    <description>Clear fuzzing results to free memory. Use after analyzing batches.</description>
-    <parameters>
-      <parameter name="batch_id" type="string" required="false">
-        <description>Specific batch to clear, or None to clear all batches.</description>
-      </parameter>
-    </parameters>
-    <returns type="Dict[str, Any]">
-      <description>Summary of cleared results with count.</description>
-    </returns>
-    <examples>
-  # Clear specific batch
-  <function=clear_fuzz_results>
-  <parameter=batch_id>FUZZ-A1B2C3D4</parameter>
-  </function>
-
-  # Clear all batches
-  <function=clear_fuzz_results>
-  </function>
-    </examples>
-  </tool>
 </tools>
