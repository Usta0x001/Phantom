diff --git a/phantom/tools/oast/oast_actions_schema.xml b/phantom/tools/oast/oast_actions_schema.xml
index e21dea5..156b857 100644
--- a/phantom/tools/oast/oast_actions_schema.xml
+++ b/phantom/tools/oast/oast_actions_schema.xml
@@ -1,147 +1,2 @@
 <tools>
-  <tool name="generate_oast_payload">
-    <description>Generate an OAST (Out-of-Band Application Security Testing) callback payload for detecting blind vulnerabilities. Use this when testing vulnerabilities that don't produce visible output but might cause the server to make external requests (blind SSRF, XXE, RCE, SQL out-of-band, etc.).</description>
-    <parameters>
-      <parameter name="payload_type" type="string" required="true">
-        <description>Type of callback to generate:
-        - "http": HTTP/HTTPS callback URL (most common, works for SSRF, XXE, RCE)
-        - "dns": DNS-only callback (useful when HTTP is blocked, works for DNS exfiltration)
-        - "smtp": Email callback (for email injection testing)
-        - "ldap": LDAP callback (for JNDI injection like Log4j)</description>
-      </parameter>
-      <parameter name="context" type="string" required="true">
-        <description>What vulnerability you're testing for. Examples:
-        - "ssrf": Server-Side Request Forgery
-        - "xxe": XML External Entity
-        - "rce": Remote Code Execution
-        - "sqli_oob": SQL Injection Out-of-Band
-        - "log4j": Log4Shell JNDI injection
-        - "ssti": Server-Side Template Injection
-        - "command_injection": OS Command Injection</description>
-      </parameter>
-      <parameter name="target_surface" type="string" required="true">
-        <description>Where you'll inject the payload (for tracking). Examples:
-        - "/api/fetch?url=PAYLOAD"
-        - "POST /upload body parameter 'file_url'"
-        - "XML entity in POST /process"</description>
-      </parameter>
-    </parameters>
-    <returns type="Dict[str, Any]">
-      <description>Response containing:
-        - 'payload_id': Unique ID for this payload (use with check_oast_interactions)
-        - 'callback_url': The callback URL/domain to monitor
-        - 'raw_payload': The exact string to inject in your request
-        - 'instructions': Context-specific usage hints
-        - 'payload_type', 'context', 'target_surface': Echo of your parameters</description>
-    </returns>
-    <examples>
-  # Test for blind SSRF via HTTP callback
-  <function=generate_oast_payload>
-  <parameter=payload_type>http</parameter>
-  <parameter=context>ssrf</parameter>
-  <parameter=target_surface>/api/fetch?url=PAYLOAD</parameter>
-  </function>
-
-  # Test for XXE with HTTP callback
-  <function=generate_oast_payload>
-  <parameter=payload_type>http</parameter>
-  <parameter=context>xxe</parameter>
-  <parameter=target_surface>POST /process XML entity</parameter>
-  </function>
-
-  # Test for RCE with DNS callback (stealthier)
-  <function=generate_oast_payload>
-  <parameter=payload_type>dns</parameter>
-  <parameter=context>rce</parameter>
-  <parameter=target_surface>POST /exec command parameter</parameter>
-  </function>
-
-  # Test for Log4j with LDAP callback
-  <function=generate_oast_payload>
-  <parameter=payload_type>ldap</parameter>
-  <parameter=context>log4j</parameter>
-  <parameter=target_surface>User-Agent header</parameter>
-  </function>
-    </examples>
-  </tool>
-
-  <tool name="check_oast_interactions">
-    <description>Check for out-of-band interactions on OAST payloads. Call this after injecting OAST payloads to see if any callbacks were received. Interactions indicate the server made a request to your callback URL, confirming a blind vulnerability.</description>
-    <parameters>
-      <parameter name="payload_id" type="string" required="false">
-        <description>Specific payload ID to check (from generate_oast_payload), or omit to check all payloads.</description>
-      </parameter>
-    </parameters>
-    <returns type="Dict[str, Any]">
-      <description>For specific payload:
-        - 'payload_id', 'context', 'target_surface': Payload details
-        - 'interactions': List of interaction events (source IP, timestamp, raw data)
-        - 'interaction_count': Number of callbacks received
-        - 'has_interactions': Boolean - true if any callbacks received
-
-      For all payloads:
-        - 'total_payloads': Total OAST payloads generated
-        - 'payloads_with_interactions': List of payload IDs that received callbacks
-        - 'interactions': All interaction events across all payloads
-        - 'has_any_interactions': Boolean - true if any payload received callbacks</description>
-    </returns>
-    <examples>
-  # Check specific payload
-  <function=check_oast_interactions>
-  <parameter=payload_id>OAST-A1B2C3D4</parameter>
-  </function>
-
-  # Check all payloads
-  <function=check_oast_interactions>
-  </function>
-    </examples>
-  </tool>
-
-  <tool name="list_oast_payloads">
-    <description>List all generated OAST payloads and their interaction status. Use this to review what OAST payloads have been created and which ones have received callbacks.</description>
-    <parameters>
-    </parameters>
-    <returns type="Dict[str, Any]">
-      <description>Response containing:
-        - 'total_payloads': Total number of generated payloads
-        - 'payloads': List of payload objects with:
-          - 'payload_id': Unique ID
-          - 'payload_type': http/dns/smtp/ldap
-          - 'context': What vulnerability was being tested
-          - 'target_surface': Where it was injected
-          - 'callback_url': The callback URL
-          - 'interaction_count': Number of callbacks received
-          - 'has_interactions': Boolean
-          - 'created_at': Timestamp
-        - 'oast_server': The OAST server domain being used</description>
-    </returns>
-    <examples>
-  <function=list_oast_payloads>
-  </function>
-    </examples>
-  </tool>
-
-  <tool name="clear_oast_payloads">
-    <description>Clear OAST payloads from tracking. Use this to clean up old payloads that are no longer needed.</description>
-    <parameters>
-      <parameter name="older_than_hours" type="number" required="false">
-        <description>Only clear payloads older than this many hours. Omit to clear all payloads.</description>
-      </parameter>
-    </parameters>
-    <returns type="Dict[str, Any]">
-      <description>Response containing:
-        - 'cleared_count': Number of payloads cleared
-        - 'remaining_count': Number of payloads still tracked</description>
-    </returns>
-    <examples>
-  # Clear all payloads
-  <function=clear_oast_payloads>
-  </function>
-
-  # Clear payloads older than 24 hours
-  <function=clear_oast_payloads>
-  <parameter=older_than_hours>24</parameter>
-  </function>
-    </examples>
-  </tool>
 </tools>
