   <tool name="refresh_jwt_token">
-    <description>
-      Refresh expired JWT token to maintain authentication.
-      
-      JWT tokens typically expire after 15-60 minutes. This tool
-      automatically refreshes the access token using a refresh token.
-      
-      ELITE FEATURE: During long scan operations, JWT tokens may expire.
-      Use this tool to refresh tokens mid-scan and maintain access to
-      protected endpoints.
-      
-      Supports:
-      - Automatic refresh using cached refresh token
-      - Manual refresh with provided refresh token
-      - Updates session with new access token
-      - Caches new token for future refreshes
-    </description>
+    <description>Refresh expired JWT token.</description>
     <parameters>
       <parameter name="session_id" type="string" required="true">
-        Session ID to refresh token for
+        <description>Session ID.</description>
       </parameter>
       <parameter name="refresh_token" type="string" required="false">
-        Refresh token (optional if previously cached)
+        <description>Refresh token (if not cached).</description>
       </parameter>
       <parameter name="refresh_endpoint" type="string" required="false">
-        Token refresh endpoint URL (e.g., "https://api.target.com/auth/refresh")
+        <description>Refresh endpoint URL.</description>
       </parameter>
     </parameters>
-    <returns>
-      JSON object containing:
-      - success: Whether token refresh succeeded
-      - session_id: Updated session ID
-      - access_token: New access token (redacted)
-      - token_refreshed: True if successful
-      - expires_in: Token expiration time (if provided by API)
-      - message: Status message
+    <returns type="Dict[str, Any]">
