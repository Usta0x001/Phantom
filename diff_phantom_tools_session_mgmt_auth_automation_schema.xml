-  <tool name="extract_jwt_from_response">
-    <description>
-      Extract JWT tokens from HTTP response body and headers.
-      
-      Searches for JWT tokens in:
-      - JSON response bodies: {"token": "...", "access_token": "...", "id_token": "..."}
-      - Authorization response headers: Authorization: Bearer ...
-      - Refresh tokens: {"refresh_token": "..."}
-      
-      Automatically parses token claims:
-      - Issuer (iss)
-      - Subject (sub)
-      - Expiration (exp)
-      - Issued at (iat)
-      
-      ELITE FEATURE: Many modern web apps use JWT for authentication.
-      This tool extracts tokens from API responses and validates their
-      format before use.
-    </description>
-    <parameters>
-      <parameter name="response_body" type="string" required="true">
-        HTTP response body (JSON or HTML)
-      </parameter>
-      <parameter name="response_headers" type="object" required="false">
-        HTTP response headers as dict
-      </parameter>
-      <parameter name="session_id" type="string" required="false">
-        Session to store extracted token in (optional)
-      </parameter>
-    </parameters>
-    <returns>
-      JSON object containing:
-      - success: Whether any tokens were found
-      - tokens: List of extracted tokens with parsed claims
-      - token_count: Number of tokens found
-      - primary_token: Most likely token with claims
-      - refresh_tokens: List of refresh tokens found
-      - stored_in_session: Session ID if token stored
-      - message: Status message
-    </returns>
-    <example>
-      <!-- Extract JWT from API login response -->
-      extract_jwt_from_response(
-        response_body='{"access_token":"eyJhbGc...", "refresh_token":"dGhpc2lz..."}'
-      )
-      
-      <!-- Extract and store in session -->
-      extract_jwt_from_response(
-        response_body=api_response,
-        response_headers={"Authorization": "Bearer eyJhbGc..."},
-        session_id="abc12345"
-      )
-    </example>
-    <workflow>
-      1. Perform API authentication request
-      2. Call extract_jwt_from_response() on response
-      3. Tool parses JWT and validates format
-      4. Extracts token claims (expiration, subject, etc.)
-      5. Stores token in session if session_id provided
-      6. Use extracted token for authenticated API requests
-    </workflow>
-  </tool>
-
-  <tool name="check_jwt_expiration">
-    <description>
-      Check JWT token expiration status and validity.
-      
-      Parses JWT token to determine:
-      - Is token expired?
-      - Is token expiring soon? (within 5 minutes)
-      - Time remaining until expiration
-      - Token claims (issuer, subject, etc.)
-      
-      ELITE FEATURE: Proactively check token expiration before
-      making critical requests. Prevents authentication failures
-      mid-scan by refreshing tokens before they expire.
-    </description>
-    <parameters>
-      <parameter name="token" type="string" required="false">
-        JWT token to check (optional)
-      </parameter>
-      <parameter name="session_id" type="string" required="false">
-        Session ID to check cached token (alternative to token parameter)
-      </parameter>
-    </parameters>
-    <returns>
-      JSON object containing:
-      - success: Whether check completed
-      - has_expiration: Whether token has exp claim
-      - is_expired: True if token is expired
-      - expires_soon: True if expiring within 5 minutes
-      - expires_at: ISO timestamp of expiration
-      - time_remaining_seconds: Seconds until expiration
-      - claims: Full JWT claims
-      - recommendation: Action to take (refresh, valid, etc.)
-    </returns>
-    <example>
-      <!-- Check specific token -->
-      check_jwt_expiration(token="eyJhbGciOiJIUzI1NiIsInR5c...")
-      
-      <!-- Check cached session token -->
-      check_jwt_expiration(session_id="abc12345")
-    </example>
-    <workflow>
-      1. Before critical authenticated request, check token expiration
-      2. Call check_jwt_expiration(session_id="...")
-      3. If is_expired or expires_soon, call refresh_jwt_token()
-      4. Proceed with request using valid token
-    </workflow>
-  </tool>
-
-  <tool name="multi_step_login">
-    <description>
-      Execute complex multi-step authentication flows.
-      
-      Handles authentication requiring multiple sequential requests:
-      - Multi-page login forms
-      - Two-factor authentication (2FA)
-      - OAuth2 authorization code flow
-      - SAML SSO workflows
-      - CSRF token extraction + login + redirect
-      
-      ELITE FEATURE: Modern enterprise apps often have complex auth.
-      This tool chains requests together, extracting tokens/cookies
-      at each step and passing them to subsequent steps.
-      
-      Each step can:
-      - GET or POST to URLs
-      - Extract CSRF tokens
-      - Extract JWT tokens
-      - Parse and store cookies
-      - Inject data from previous steps
-      - Check for success/failure indicators
-    </description>
-    <parameters>
-      <parameter name="steps" type="array" required="true">
-        List of step configurations. Each step is a dict with:
-        - type: "get" or "post"
-        - url: Request URL
-        - data: Form/JSON data (for POST)
-        - extract_csrf: Extract CSRF token (bool)
-        - extract_jwt: Extract JWT token (bool)
-        - inject_csrf: Inject CSRF into form (bool)
-        - csrf_field: Field name for CSRF (default: "csrf_token")
-        - content_type: "form" or "json"
-        - failure_indicators: List of strings indicating failure
-      </parameter>
-      <parameter name="session_name" type="string" required="false">
-        Name for the created session (default: auto-generated)
-      </parameter>
-    </parameters>
-    <returns>
-      JSON object containing:
-      - success: Whether all steps completed successfully
-      - session_id: Created session ID
-      - session_name: Session name
-      - cookies: Final cookies (redacted)
-      - headers: Final headers (redacted)
-      - csrf_token: Final CSRF token (redacted)
-      - steps_executed: Number of steps completed
-      - step_results: Results from each step
-      - duration_ms: Total flow duration
-      - message: Status message
-    </returns>
-    <example>
-      <!-- Two-step login with CSRF -->
-      multi_step_login(
-        steps=[
-          {
-            "type": "get",
-            "url": "https://target.com/login",
-            "extract_csrf": true
-          },
-          {
-            "type": "post",
-            "url": "https://target.com/login",
-            "data": {"username": "admin", "password": "test123"},
-            "inject_csrf": true,
-            "csrf_field": "csrf_token"
-          }
-        ],
-        session_name="two_step_auth"
-      )
-      
-      <!-- OAuth2 + API call -->
-      multi_step_login(
-        steps=[
-          {
-            "type": "post",
-            "url": "https://api.target.com/oauth/token",
-            "data": {"grant_type": "password", "username": "admin", "password": "test"},
-            "content_type": "json",
-            "extract_jwt": true
-          },
-          {
-            "type": "get",
-            "url": "https://api.target.com/user/profile"
-          }
-        ]
-      )
-    </example>
-    <workflow>
-      1. Define authentication steps as list of dicts
-      2. Call multi_step_login(steps=[...])
-      3. Tool executes steps sequentially
-      4. Each step can extract/inject CSRF, JWT, cookies
-      5. Cookies and tokens accumulated across steps
-      6. Final session created with all auth data
-      7. Use session_id for authenticated scanning
-    </workflow>
+    <examples>
+      <function=refresh_jwt_token>
+        <parameter=session_id>abc123</parameter>
+      </function>
+    </examples>
   </tool>
 </tools>
