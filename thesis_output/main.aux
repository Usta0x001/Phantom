\@writefile{lof}{\contentsline {figure}{\numberline {6.1}{\ignorespaces Multi-agent runtime topology. Solid arrows~=~spawn; dashed arrows~=~result messages via \texttt  {send\_message\_to\_agent}. Each sub-agent has an independent \texttt  {LLM} instance and \texttt  {AgentState}; the \texttt  {HypothesisLedger} is shared. Sub-agents do not share \texttt  {AgentState} with each other or with the root, which means reasoning traces are not shared---only deduplication state.}}{21}{figure.caption.18}\protected@file@percent }
\newlabel{fig:multi_agent}{{6.1}{21}{Multi-agent runtime topology. Solid arrows~=~spawn; dashed arrows~=~result messages via \tool {send\_message\_to\_agent}. Each sub-agent has an independent \code {LLM} instance and \code {AgentState}; the \code {HypothesisLedger} is shared. Sub-agents do not share \code {AgentState} with each other or with the root, which means reasoning traces are not shared---only deduplication state}{figure.caption.18}{}}
